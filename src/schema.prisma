CREATE TABLE users (id uuid PRIMARY KEY, email text, created_at timestamptz DEFAULT now()); CREATE TABLE events (id uuid PRIMARY KEY, user_id uuid REFERENCES users(id), date date, title text, description text, is_holiday boolean DEFAULT false, created_at timestamptz DEFAULT now()); CREATE TABLE reminders (id uuid PRIMARY KEY, user_id uuid REFERENCES users(id), event_id uuid REFERENCES events(id), notify_at timestamptz, is_sent boolean DEFAULT false, created_at timestamptz DEFAULT now());